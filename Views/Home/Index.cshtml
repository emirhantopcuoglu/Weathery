@{
    ViewData["Title"] = "Hoşgeldiniz";
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Weathery · Modern Hava Durumu</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/weathery.css" asp-append-version="true" />
</head>
<body class="weather-clear-day" data-weather="clear-day">
    <div class="fx-layer"></div>

    <button class="theme-toggle" type="button" aria-label="Tema değiştir"
            style="position: fixed; top: 1.5rem; right: 1.5rem; z-index: 5;">
        <i class="bi bi-moon-stars-fill"></i>
    </button>

    <div class="home-hero">
        <h1 class="home-logo">Weathery</h1>
        <p class="home-tagline">
            Şehrin hava durumunu zarif bir şekilde keşfet — anlık koşullar, 5 günlük tahmin ve canlı atmosfer.
        </p>

        <div class="home-cards">
            <a href="@Url.Action("Index", "WeatherInfo")" class="glass home-card">
                <div class="icon">☀️</div>
                <div class="title">Anlık Hava Durumu</div>
                <div class="subtitle">Şu anki sıcaklık, nem, rüzgar ve daha fazlası</div>
            </a>
            <a href="@Url.Action("Index", "Forecast")" class="glass home-card">
                <div class="icon">⛅</div>
                <div class="title">5 Günlük Tahmin</div>
                <div class="subtitle">Günlük özet ve 3 saatlik detaylar</div>
            </a>
        </div>

        <div class="home-footer">&copy; @DateTime.Now.Year Weathery</div>
    </div>

    <script src="~/js/weathery.js" asp-append-version="true"></script>
</body>
</html>
