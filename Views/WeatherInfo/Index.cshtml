@model WeatherInfo
@{
    ViewData["Title"] = "Anlık Hava Durumu";
    var trCulture = new System.Globalization.CultureInfo("tr-TR");
}
<link rel="stylesheet" href="~/css/styles.css" />
<div class="container mt-5">
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger" role="alert">
            @TempData["Error"]
        </div>
    }

    @if (Model != null)
    {
        <div class="card shadow-lg rounded-4 border-0">
            <div class="card-header" style="background-color: @WeatherDisplay.BackgroundColor(Model.Temperature);">
                <div class="d-flex justify-content-between align-items-center">
                    <h3 class="text-white">@Model.City</h3>
                    <h3 class="text-white">@Model.Date.ToString("d MMMM yyyy dddd", trCulture)</h3>
                </div>
            </div>

            <div class="card-body">
                <div class="row g-4">
                    <div class="col-sm-6 col-md-3">
                        <div class="card p-3 rounded-3 shadow-sm">
                            <h5 class="text-center text-primary">
                                <i class="bi bi-thermometer-half weather-icon"
                                   style="color: @WeatherDisplay.TemperatureIconColor(Model.Temperature);"></i>
                                <br>
                                <strong>Sıcaklık</strong>
                            </h5>
                            <p class="text-center weather-value">@(Math.Round(Model.Temperature)) °C</p>
                        </div>
                    </div>

                    <div class="col-sm-6 col-md-3">
                        <div class="card p-3 rounded-3 shadow-sm">
                            <h5 class="text-center text-secondary">
                                <img src="@WeatherDisplay.IconUrl(Model.Icon)" alt="Hava Durumu" class="weather-img">
                                <br>
                                <strong>Hava Durumu</strong>
                            </h5>
                            <p class="text-center lead weather-text">@Model.Description</p>
                        </div>
                    </div>

                    <div class="col-sm-6 col-md-3">
                        <div class="card p-3 rounded-3 shadow-sm">
                            <h5 class="text-center text-info">
                                <i class="bi bi-moisture weather-icon"></i>
                                <br>
                                <strong>Nem</strong>
                            </h5>
                            <p class="text-center lead weather-text">% @Model.Humidity</p>
                        </div>
                    </div>

                    <div class="col-sm-6 col-md-3">
                        <div class="card p-3 rounded-3 shadow-sm">
                            <h5 class="text-center text-warning">
                                <i class="bi bi-wind weather-icon"
                                   style="color: @WeatherDisplay.WindIconColor(Model.WindSpeed);"></i>
                                <br>
                                <strong>Rüzgar</strong>
                            </h5>
                            <p class="text-center lead weather-text">@Model.WindSpeed m/s</p>
                        </div>
                    </div>

                    <div class="col-sm-6 col-md-3">
                        <div class="card p-3 rounded-3 shadow-sm">
                            <h5 class="text-center text-primary">
                                <i class="bi bi-cloud-hail weather-icon"></i>
                                <br>
                                <strong>Yağış</strong>
                            </h5>
                            <p class="text-center lead weather-text">@Model.Rain mm</p>
                        </div>
                    </div>

                    <div class="col-sm-6 col-md-3">
                        <div class="card p-3 rounded-3 shadow-sm">
                            <h5 class="text-center text-success">
                                <i class="bi bi-sunrise weather-icon"></i>
                                <br>
                                <strong>Gün Doğumu</strong>
                            </h5>
                            <p class="text-center lead weather-text">@Model.SunRise.ToString("HH:mm dd-MM-yyyy")</p>
                        </div>
                    </div>

                    <div class="col-sm-6 col-md-3">
                        <div class="card p-3 rounded-3 shadow-sm">
                            <h5 class="text-center text-danger">
                                <i class="bi bi-sunset weather-icon"></i>
                                <br>
                                <strong>Gün Batımı</strong>
                            </h5>
                            <p class="text-center lead weather-text">@Model.SunSet.ToString("HH:mm dd-MM-yyyy")</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
