@model WeatherInfo
@{
    ViewData["Title"] = Model?.City ?? "Anlık Hava Durumu";
    var trCulture = new System.Globalization.CultureInfo("tr-TR");
    if (Model != null)
    {
        ViewData["WeatherCondition"] = Model.Condition ?? "default";
    }
}

@if (TempData["Error"] != null)
{
    <div class="weathery-alert">
        <i class="bi bi-exclamation-triangle-fill"></i>
        <span>@TempData["Error"]</span>
    </div>
}

@if (Model == null)
{
    <div class="glass weather-hero">
        <p class="text-center text-muted mb-0">Görüntülenecek veri yok. Yukarıdan bir şehir aratın.</p>
    </div>
    return;
}

<section class="glass weather-hero">
    <div class="weather-hero-top">
        <div>
            <h1 class="weather-city">
                @Model.City<span class="country">@Model.Country</span>
            </h1>
            <div class="weather-date">@Model.Date.ToString("d MMMM yyyy, dddd · HH:mm", trCulture)</div>
        </div>
        <div class="text-end">
            <div class="weather-desc">@Model.Description</div>
            <div class="weather-feels">Hissedilen <strong>@Math.Round(Model.FeelsLike) °C</strong></div>
            <div class="weather-range">
                <i class="bi bi-arrow-down"></i> @Math.Round(Model.TempMin)°
                &nbsp;<i class="bi bi-arrow-up"></i> @Math.Round(Model.TempMax)°
            </div>
        </div>
    </div>

    <div class="weather-hero-main">
        <i class="bi @Model.Icon weather-icon-big" aria-hidden="true"></i>
        <div class="weather-temp">
            <span data-count data-value="@Math.Round(Model.Temperature)">@Math.Round(Model.Temperature)</span>
            <span class="unit">°C</span>
        </div>
    </div>
</section>

<section class="detail-grid">
    <div class="glass detail-card">
        <span class="detail-label"><i class="bi bi-droplet-half"></i> Nem</span>
        <span class="detail-value"><span data-count data-value="@Model.Humidity" data-suffix="%">@Model.Humidity%</span></span>
        <span class="detail-sub">Bağıl nem oranı</span>
    </div>

    <div class="glass detail-card">
        <span class="detail-label"><i class="bi bi-wind"></i> Rüzgar</span>
        <span class="detail-value">@Model.WindSpeed.ToString("0.#") m/s</span>
        <span class="detail-sub">@WeatherDisplay.WindDirection(Model.WindDeg) yönünden</span>
    </div>

    <div class="glass detail-card">
        <span class="detail-label"><i class="bi bi-speedometer2"></i> Basınç</span>
        <span class="detail-value">@Model.Pressure.ToString("0") hPa</span>
        <span class="detail-sub">Atmosferik basınç</span>
    </div>

    <div class="glass detail-card">
        <span class="detail-label"><i class="bi bi-cloud-rain"></i> Yağış</span>
        <span class="detail-value">@Model.Rain.ToString("0.#") mm</span>
        <span class="detail-sub">Son ölçüm</span>
    </div>

    <div class="glass detail-card">
        <span class="detail-label"><i class="bi bi-sunrise"></i> Gün Doğumu</span>
        <span class="detail-value">@Model.SunRise.ToString("HH:mm")</span>
        <span class="detail-sub">@Model.SunRise.ToString("d MMM", trCulture)</span>
    </div>

    <div class="glass detail-card">
        <span class="detail-label"><i class="bi bi-sunset"></i> Gün Batımı</span>
        <span class="detail-value">@Model.SunSet.ToString("HH:mm")</span>
        <span class="detail-sub">@Model.SunSet.ToString("d MMM", trCulture)</span>
    </div>

    <div class="glass detail-card">
        <span class="detail-label"><i class="bi bi-thermometer-half"></i> Hissedilen</span>
        <span class="detail-value">@Math.Round(Model.FeelsLike)°C</span>
        <span class="detail-sub">Vücudun algıladığı</span>
    </div>

    <div class="glass detail-card">
        <span class="detail-label"><i class="bi bi-geo-alt"></i> Konum</span>
        <span class="detail-value">@Model.Latitude.ToString("0.##"), @Model.Longitude.ToString("0.##")</span>
        <span class="detail-sub">Enlem / Boylam</span>
    </div>
</section>
