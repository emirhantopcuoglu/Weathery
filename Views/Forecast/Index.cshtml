@model ForecastData
@{
    ViewData["Title"] = "5 Günlük Tahmin";
    const int slotCount = 8;
    const int hoursPerSlot = 3;
}
<link rel="stylesheet" href="~/css/forecast_styles.css" />
<div class="container mt-5">
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger text-center" role="alert">
            @TempData["Error"]
        </div>
    }

    @if (Model != null)
    {
        <h1 class="text-center text-primary mb-4">@Model.City, @Model.Country</h1>

        <div class="card shadow-lg border-0 rounded-3 forecast-card">
            <div class="card-header forecast-header">
                <strong class="text-white">5 Günlük / 3 Saatlik Hava Tahminleri</strong>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-bordered table-hover forecast-table">
                        <thead>
                            <tr>
                                <th class="text-center forecast-th">Tarih / Saat</th>
                                @foreach (var hour in Enumerable.Range(0, slotCount))
                                {
                                    <th class="text-center forecast-th">@((hour * hoursPerSlot).ToString("00")):00</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var dayGroup in Model.Forecasts.GroupBy(f => f.DateTime.Date))
                            {
                                <tr>
                                    <td class="align-middle text-center text-dark forecast-day">
                                        @dayGroup.Key.ToString("dd MMM yyyy")
                                    </td>

                                    @foreach (var hour in Enumerable.Range(0, slotCount))
                                    {
                                        var forecast = dayGroup.FirstOrDefault(f => f.DateTime.Hour == hour * hoursPerSlot);
                                        if (forecast != null)
                                        {
                                            <td class="text-center forecast-cell">
                                                <div class="forecast-cell-content">
                                                    <i class="bi bi-thermometer-half text-warning forecast-icon"></i>
                                                    <span class="d-block fs-5 forecast-temp">@(Math.Round(forecast.Temperature)) °C</span>
                                                    <div class="text-muted fs-6">@forecast.Description</div>
                                                </div>
                                            </td>
                                        }
                                        else
                                        {
                                            <td class="text-center text-muted forecast-empty">-</td>
                                        }
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>
