@model ForecastData
@{
    ViewData["Title"] = Model != null ? $"{Model.City} · 5 Günlük Tahmin" : "5 Günlük Tahmin";
    var trCulture = new System.Globalization.CultureInfo("tr-TR");
    if (Model?.Daily.FirstOrDefault() is { } first)
    {
        ViewData["WeatherCondition"] = WeatherDisplay.ConditionClass(first.Condition, first.Icon).Replace("weather-", "");
    }
}

@if (TempData["Error"] != null)
{
    <div class="weathery-alert">
        <i class="bi bi-exclamation-triangle-fill"></i>
        <span>@TempData["Error"]</span>
    </div>
}

@if (Model == null)
{
    <div class="glass forecast-section">
        <p class="text-center text-muted mb-0">Görüntülenecek tahmin yok. Yukarıdan bir şehir aratın.</p>
    </div>
    return;
}

<section class="glass forecast-section">
    <h2 class="forecast-title">
        <i class="bi bi-calendar3 me-2"></i>@Model.City, @Model.Country — Günlük Özet
    </h2>

    <div class="daily-grid">
        @{ int dayIndex = 0; }
        @foreach (var day in Model.Daily)
        {
            var dateKey = day.Date.ToString("yyyy-MM-dd");
            <div class="glass day-card" data-date="@dateKey" style="animation-delay: @(dayIndex * 60)ms">
                <div class="day-name">@day.Date.ToString("dddd", trCulture)</div>
                <div class="day-date">@day.Date.ToString("d MMM", trCulture)</div>
                <img src="@WeatherDisplay.IconUrl(day.Icon)" alt="@day.Description">
                <div class="day-temps">
                    <span class="day-max">@Math.Round(day.TempMax)°</span>
                    <span class="day-min">@Math.Round(day.TempMin)°</span>
                </div>
                <div class="day-desc">@day.Description</div>
            </div>
            dayIndex++;
        }
    </div>

    <h2 class="forecast-title">
        <i class="bi bi-clock me-2"></i>3 Saatlik Detay
    </h2>

    <div data-hourly-strips>
        @foreach (var day in Model.Daily)
        {
            var dateKey = day.Date.ToString("yyyy-MM-dd");
            <div class="hourly-strip" data-strip-for="@dateKey">
                @{ int slotIndex = 0; }
                @foreach (var slot in day.Slots)
                {
                    <div class="glass hour-card" style="animation-delay: @(slotIndex * 40)ms">
                        <div class="hour-time">@slot.DateTime.ToString("HH:mm")</div>
                        <img src="@WeatherDisplay.IconUrl(slot.Icon)" alt="@slot.Description">
                        <div class="hour-temp">@Math.Round(slot.Temperature)°</div>
                        <div class="day-desc">@slot.Description</div>
                    </div>
                    slotIndex++;
                }
            </div>
        }
    </div>
</section>
