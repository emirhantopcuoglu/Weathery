@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var action = ViewContext.RouteData.Values["action"]?.ToString();
    var hideNav = string.Equals(controller, "Home", StringComparison.OrdinalIgnoreCase)
                  && string.Equals(action, "Index", StringComparison.OrdinalIgnoreCase);
    var bodyWeather = ViewData["WeatherCondition"] as string ?? "default";
    var bodyClass = $"weather-{bodyWeather}";
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] · Weathery</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/weathery.css" asp-append-version="true" />
</head>
<body class="@bodyClass" data-weather="@bodyWeather">
    <div class="fx-layer"></div>

    @if (!hideNav)
    {
        <nav class="weathery-navbar d-flex align-items-center">
            <a class="navbar-brand" href="@Url.Action("Index", "Home")">
                <i class="bi bi-cloud-sun-fill"></i> Weathery
            </a>

            <form class="search-form ms-auto me-3" method="get" action="@Context.Request.Path" autocomplete="off">
                <i class="bi bi-search search-icon"></i>
                <input class="search-input" type="text" name="city"
                       placeholder="Şehir ara..." aria-label="Şehir ara" required>
                <button class="search-btn" type="submit">Ara</button>
                <ul class="recent-suggestions" aria-label="Son aranan şehirler"></ul>
            </form>

            <div class="d-none d-md-flex align-items-center gap-2 me-3">
                <a class="nav-link" href="@Url.Action("Index", "WeatherInfo")">Anlık</a>
                <a class="nav-link" href="@Url.Action("Index", "Forecast")">5 Gün</a>
            </div>

            <button class="theme-toggle" type="button" aria-label="Tema değiştir" title="Tema değiştir">
                <i class="bi bi-moon-stars-fill"></i>
            </button>
        </nav>
    }

    <main class="container">
        @RenderBody()
    </main>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/weathery.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
